# worker/.env.example
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001

# ======== 联网搜索（agentic 模型后端）========
# 当前仅支持 Tavily。DeepSeek/MiniMax 等服务端无联网能力的模型，会通过 agentic 工具循环调用此处配置。
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 搜索深度：ultra-fast | fast | basic | advanced（默认 advanced，相关性最高；basic 更省 credit）
WEB_SEARCH_DEPTH=advanced
# 单次返回结果条数（默认 15，最大 20）
WEB_SEARCH_MAX_RESULTS=15
# 是否请求原文 markdown（advanced/fast 深度生效，basic 不返回；默认 true）
WEB_SEARCH_INCLUDE_RAW_CONTENT=true
# advanced 深度下每个源返回的相关片段数（默认 3）
WEB_SEARCH_CHUNKS_PER_SOURCE=3
# Tavily 自身是否返回 AI 合成答案：false | basic | advanced（默认 false，避免二次幻觉）
WEB_SEARCH_INCLUDE_ANSWER=false
# 地域加权（可选，如 cn/us/jp 等）
WEB_SEARCH_COUNTRY=
# 主题（可选，默认留空=general；另有 news/finance，专利场景一般不用）
WEB_SEARCH_TOPIC=
# 时间窗（可选：day|week|month|year），默认留空=不限时间
WEB_SEARCH_TIME_RANGE=

# 权威域名白名单（逗号分隔）。留空使用代码内置的专利/学术域名默认集；
# 设为 * 则不做白名单过滤（不推荐，结果会混入大量 SEO 垃圾）。
# 示例：WEB_SEARCH_INCLUDE_DOMAINS=patents.google.com,arxiv.org
WEB_SEARCH_INCLUDE_DOMAINS=
# 黑名单（逗号分隔），追加到代码内置的高噪声站点集合。
WEB_SEARCH_EXCLUDE_DOMAINS=

# raw_content 在搜索服务端的截断上限（字符），默认 1200（≈600 token/条）
WEB_SEARCH_RAW_CONTENT_MAX_CHARS=1200
# 回灌给 LLM 的每条正文上限（字符），默认 800（≈400 token/条）
WEB_SEARCH_TOOL_RAW_MAX_CHARS=800
# 单次搜索超时毫秒（advanced 深度比 basic 慢，默认 15000）
WEB_SEARCH_TIMEOUT_MS=15000
# agentic 工具循环的最大轮数（默认 3）
WEB_SEARCH_MAX_ROUNDS=3
